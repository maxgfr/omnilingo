{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omnilingo",
  "version": "2.0.0",
  "identifier": "com.omnilingo.app",
  "build": {
    "frontendDist": ".."
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Omnilingo — Apprendre les langues",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v2Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/maxgfr/omnilingo/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
